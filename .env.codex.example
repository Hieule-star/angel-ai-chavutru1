# Copy to ~/.env.codex (OUTSIDE the repo) and `source ~/.env.codex` before running `codex`.
# These credentials are for the read-only `codex_readonly` Postgres role.
# NEVER commit real values.

export PGHOST="aws-0-<region>.pooler.supabase.com"   # replace <region> with your project's region
export PGPORT="6543"                                  # Supabase transaction pooler
export PGUSER="codex_readonly.sasbfslupxdsaqifnqzx"   # format: <role>.<project-ref>
export PGPASSWORD="REPLACE_WITH_PASSWORD_YOU_SET"
export PGDATABASE="postgres"
export PGSSLMODE="require"
